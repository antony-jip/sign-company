# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL + anon key (publiek, client-side leesrechten)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
# Service-role key — ALLEEN server-side (API routes / scripts). NOOIT NEXT_PUBLIC_!
SUPABASE_SERVICE_ROLE_KEY=ey...
# Storage bucket voor klant-uploads (eigen foto)
SUPABASE_UPLOAD_BUCKET=uploads

# ─── Mollie ──────────────────────────────────────────────────────────────────
# Test: test_xxx  |  Live: live_xxx
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── App ─────────────────────────────────────────────────────────────────────
# Publieke basis-URL (voor Mollie redirect + webhook). Lokaal kan Mollie de
# webhook niet bereiken; gebruik een tunnel (ngrok) of test op Vercel preview.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Verzendkosten in centen (0 = gratis verzending)
SHIPPING_CENTS=0
# BTW-percentage (NL hoog tarief = 21)
BTW_PERCENT=21

# ─── Admin back-end (/admin) ─────────────────────────────────────────────────
# Wachtwoord om in te loggen op /admin. Kies iets sterks.
ADMIN_PASSWORD=verander-dit-wachtwoord
# Geheime sleutel om de login-cookie te ondertekenen (lange willekeurige string).
# Genereer bv. met: openssl rand -hex 32
ADMIN_SESSION_SECRET=verander-dit-naar-een-lange-willekeurige-string

# ─── E-mail (Resend) ─────────────────────────────────────────────────────────
# API-key van resend.com. Zonder key worden bevestigingsmails stil overgeslagen.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Afzender (domein moet in Resend geverifieerd zijn). Tijdelijk testen kan met
# "Kunstdoekje <onboarding@resend.dev>".
MAIL_FROM=Kunstdoekje <bestellingen@kunstdoekje.nl>
# Waar de bestel-meldingen heen moeten (jouw inbox).
ORDER_NOTIFY_EMAIL=info@kunstdoekje.nl
