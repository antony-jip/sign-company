# ============================================================
# FORGEDESK - Environment Variables
# ============================================================
# Kopieer dit bestand naar .env en vul de waarden in.
# BELANGRIJK: Voeg .env NOOIT toe aan git!
# ============================================================

# --- App URLs ---
VITE_APP_URL=https://app.forgedesk.io
VITE_MARKETING_URL=https://forgedesk.io

# --- Supabase (Database & Auth) - FRONTEND ---
VITE_SUPABASE_URL=https://jouw-project.supabase.co
VITE_SUPABASE_ANON_KEY=jouw-supabase-anon-key

# --- Anthropic (Server-side only!) ---
# GEEN VITE_ prefix! Alleen beschikbaar in /api/* serverless functions
# Wordt gebruikt door Forgie (AI email functies) en algemene AI features
ANTHROPIC_API_KEY=sk-ant-jouw-anthropic-api-key

# --- SMTP Email Encryptie (Server-side only!) ---
# Sleutel voor het versleutelen van user email wachtwoorden
# Genereer met: openssl rand -hex 32
EMAIL_ENCRYPTION_KEY=jouw-32-byte-hex-encryptie-sleutel

# --- Supabase Service Role Key (Server-side only!) ---
# Voor serverless functions die user data ophalen, NOOIT in frontend!
SUPABASE_SERVICE_ROLE_KEY=jouw-service-role-key

# ============================================================
# DEPLOYMENT NOTES (Vercel)
# ============================================================
# - VITE_ prefix = wordt meegebundeld in frontend JS (PUBLIEK zichtbaar!)
# - Zonder VITE_ prefix = alleen server-side beschikbaar (VEILIG)
# - Sla geheime API keys NOOIT op met VITE_ prefix
# - Configureer bij Vercel via: Dashboard > Settings > Environment Variables
# ============================================================
