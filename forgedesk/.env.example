# ============================================================
# FORGEDESK - Environment Variables
# ============================================================
# Kopieer naar .env.local en vul de waarden in.
# BELANGRIJK: Voeg .env/.env.local NOOIT toe aan git!
# ============================================================

# --- Frontend (VITE_ prefix = PUBLIEK in browser bundle) ---
VITE_SUPABASE_URL=https://jouw-project.supabase.co
VITE_SUPABASE_ANON_KEY=jouw-supabase-anon-key
VITE_APP_URL=https://app.doen.team

# --- Supabase (Server-side only) ---
SUPABASE_URL=https://jouw-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=jouw-service-role-key

# --- AI / LLM ---
ANTHROPIC_API_KEY=sk-ant-jouw-anthropic-api-key
FAL_AI_API_KEY=jouw-fal-ai-key

# --- Email ---
# Genereer met: openssl rand -hex 32
EMAIL_ENCRYPTION_KEY=jouw-32-byte-hex-encryptie-sleutel
RESEND_API_KEY=re_jouw-resend-key

# --- Betalingen: Stripe ---
STRIPE_SECRET_KEY=sk_test_jouw-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_jouw-webhook-secret
STRIPE_PRICE_ID=price_jouw-price-id

# --- Betalingen: Mollie ---
MOLLIE_API_KEY_LIVE=live_jouw-mollie-key
MOLLIE_API_KEY_TEST=test_jouw-mollie-key
MOLLIE_WEBHOOK_SECRET=jouw-mollie-webhook-secret

# --- Inkoopfacturen ---
# Genereer met: openssl rand -base64 32
INKOOPFACTUUR_ENCRYPTION_KEY=jouw-inkoopfactuur-encryptie-sleutel

# --- Integratie Credentials Encryptie (Mollie, Exact Online) ---
# Genereer met: openssl rand -hex 32
INTEGRATION_ENCRYPTION_KEY=jouw-integratie-encryptie-sleutel

# --- KvK API ---
KVK_API_KEY=jouw-kvk-api-key
KVK_TEST_MODE=true

# --- Vercel Cron ---
# Beveiligt cron endpoints tegen ongeautoriseerde toegang.
# Vercel stuurt automatisch Authorization: Bearer ${CRON_SECRET} mee.
# Genereer met: openssl rand -hex 32
CRON_SECRET=jouw-cron-secret

# --- Rate limiting: Upstash Redis ---
# Gebruikt door api/* routes voor IP-based en user-based rate limits.
# Maak aan via https://console.upstash.com/ (free tier: 10k req/dag).
# Als beide ontbreken: rate limiting wordt uitgeschakeld (graceful degrade).
UPSTASH_REDIS_REST_URL=https://jouw-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=jouw-upstash-token

# ============================================================
# NOTEN
# ============================================================
# - VITE_ prefix = wordt meegebundeld in frontend JS (PUBLIEK!)
# - Zonder VITE_ prefix = alleen server-side (VEILIG)
# - Sla geheime API keys NOOIT op met VITE_ prefix
# - Exact Online credentials (client_id, client_secret) worden
#   per organisatie opgeslagen in de app_settings tabel.
# - Configureer bij Vercel via: Dashboard > Settings > Environment Variables
# ============================================================
